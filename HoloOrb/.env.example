# Flask 配置
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ========= 数据库配置 =========
# MySQL（推荐）：请确保已创建数据库 holoorb，并创建用户授权
# 注意：首次初始化前，需要手动执行：
#   create database holoorb default character set utf8mb4 collate utf8mb4_unicode_ci;
# DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/holoorb?charset=utf8mb4

# SQLite 兼容模式（无需安装 MySQL，默认兜底，小数据量演示可用）
DATABASE_URL=sqlite:///./holoorb.db

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# 默认管理员账号（首次启动/种子脚本会写入 users 表）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@holoorb.local
